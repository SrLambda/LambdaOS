{
  "name": "keyboard",
  "version": "0.2.0",
  "description": "Configure keyboard layout, variant, compose key, and XKB options",
  "description_es": "Configurar disposición, variante, tecla compose y opciones XKB del teclado",
  "category": "system",
  "requires_root": false,
  "dependencies": ["setxkbmap", "localectl"],
  "min_hub_version": "1.0.0",
  "actions": [
    {
      "name": "run",
      "label": "Refresh",
      "type": "execute"
    },
    {
      "name": "set-layout",
      "label": "Layout",
      "type": "select",
      "field": "keyboard.layout",
      "options": ["us", "es", "de", "fr", "gb", "it", "jp", "ru"]
    },
    {
      "name": "set-variant",
      "label": "Variant",
      "type": "select",
      "field": "keyboard.variant",
      "options": [""]
    },
    {
      "name": "set-compose",
      "label": "Compose Key",
      "type": "select",
      "field": "keyboard.options",
      "options": ["compose:ralt", "compose:lwin", "compose:menu", "compose:caps"]
    },
    {
      "name": "set-options",
      "label": "XKB Options",
      "type": "select",
      "field": "keyboard.options",
      "options": ["caps:swapescape", "ctrl:nocaps", "compose:ralt", "compose:lwin", "compose:menu", "compose:caps", "terminate:ctrl_alt_bksp", "altwin:swap_alt_win"]
    }
  ]
}
