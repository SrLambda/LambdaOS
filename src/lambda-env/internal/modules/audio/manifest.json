{
  "name": "audio",
  "version": "0.2.0",
  "description": "Configure audio: volume, mute, default sink, default source, profiles, and per-app volume",
  "description_es": "Configurar audio: volumen, silencio, salida, entrada, perfiles y volumen por aplicación",
  "category": "system",
  "requires_root": false,
  "dependencies": ["pactl", "wpctl"],
  "min_hub_version": "1.0.0",
  "actions": [
    {
      "name": "run",
      "label": "Refresh",
      "type": "execute"
    },
    {
      "name": "set-volume",
      "label": "Volume",
      "type": "text",
      "field": "audio.volume"
    },
    {
      "name": "set-mute",
      "label": "Mute",
      "type": "toggle",
      "field": "audio.muted"
    },
    {
      "name": "set-sink",
      "label": "Default Sink",
      "type": "select",
      "field": "audio.default_sink",
      "options": ["auto"]
    },
    {
      "name": "set-source",
      "label": "Default Source",
      "type": "select",
      "field": "audio.default_source",
      "options": ["auto"]
    },
    {
      "name": "set-profile",
      "label": "Profile",
      "type": "select",
      "field": "audio.profile",
      "options": [""]
    },
    {
      "name": "set-app-volume",
      "label": "App Volume",
      "type": "select",
      "options": [""]
    }
  ]
}
